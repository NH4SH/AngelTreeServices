{
  "name": "@angel-tree/platform",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:lan": "next dev --webpack --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start --hostname 0.0.0.0 --port 3000",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "test:payments": "node --test --experimental-strip-types src/lib/payments/*.test.mjs",
    "test:security": "node --test --experimental-strip-types src/lib/security/*.test.mjs"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.8.0",
    "@stripe/stripe-js": "^9.10.0",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "lucide-react": "^1.22.0",
    "next": "^16.2.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.35.3",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "$sharp"
  }
}
