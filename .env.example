# Supabase project URL and anon key are safe to expose to browser code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase credentials.
# WARNING: SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security.
# Never import it into client components or expose it in browser JavaScript, static files, or public logs.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated public website origins allowed to submit leads.
# Defaults already include angeltreeservices.org, www.angeltreeservices.org, and local static testing on port 8000.
LEAD_INTAKE_ALLOWED_ORIGINS=

# Server-only transactional email settings for Resend.
# Do not commit real API keys.
RESEND_API_KEY=
EMAIL_FROM="Angel Tree Services <info@angeltreeservice.org>"
EMAIL_REPLY_TO="info@angeltreeservice.org"
INTERNAL_LEAD_NOTIFICATION_EMAIL="info@angeltreeservice.org"

# Public Google Business review destination used in copy-only review request drafts.
# This is safe to expose in browser code. The app does not send messages or submit reviews.
NEXT_PUBLIC_GOOGLE_REVIEW_URL=

# Direct database URL for migrations and server-only tooling.
# Keep this out of client code and never commit real credentials.
SUPABASE_DB_URL=
